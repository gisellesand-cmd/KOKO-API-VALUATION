{
  "id": null,
  "uid": "koko-mls-api",
  "title": "KOKO MLS — API Overview",
  "tags": ["koko", "mls", "api"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(http_requests_total, instance)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "label": "instance",
        "hide": 0,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests/s by endpoint",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Prometheus",
          "expr": "sum by (handler) (rate(http_requests_total[5m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 latency by endpoint (ms)",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "heatmap",
      "title": "comparables_count distribution",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "options": {
        "calculate": false,
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false
        },
        "color": {
          "scheme": "Spectral",
          "mode": "scheme",
          "steps": 64
        },
        "cellGap": 1,
        "tooltip": {
          "show": true,
          "yHistogram": false
        },
        "legend": {
          "show": true
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Prometheus",
          "expr": "sum by (le) (rate(valuation_comparables_count_bucket[10m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Scrape runs success rate",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": "Prometheus",
          "expr": "sum(rate(scrape_runs_total{status=\"success\"}[1h])) / sum(rate(scrape_runs_total[1h]))",
          "legendFormat": "success rate"
        }
      ]
    }
  ]
}
