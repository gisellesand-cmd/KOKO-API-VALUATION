# =============================================================================
# KOKO MLS Property Valuation API - Environment variables
# Copy this file to .env.local (for docker compose) or .env (for local runs)
# and fill in the values. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Application runtime
# -----------------------------------------------------------------------------

# Deployment environment. One of: development | staging | production
ENVIRONMENT=development

# Logging verbosity. One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Data stores
# -----------------------------------------------------------------------------

# Async SQLAlchemy URL for Postgres. Uses the `postgres` service name when
# running under docker compose; swap host for production deployments.
DATABASE_URL=postgresql+asyncpg://koko:koko_dev@postgres:5432/koko_mls
ECHO_SQL=false

# Redis connection URL (cache, rate limiting, scraper queues).
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# HTTP / API
# -----------------------------------------------------------------------------

# Comma-separated list of origins allowed by FastAPI CORS middleware.
CORS_ORIGINS=http://localhost:3000,https://koko.mx

# Port the FastAPI app listens on inside the container.
API_PORT=8080

# -----------------------------------------------------------------------------
# External integrations
# -----------------------------------------------------------------------------

# Token de Banxico SIE para FIX USD/MXN. Obtenerlo en
# https://www.banxico.org.mx/SieAPIRest/service/v1/token
BANXICO_API_TOKEN=

# Rate limit (requests per second) for the Vivanuncios scraper.
VIVANUNCIOS_RATE_LIMIT_RPS=0.5

# How often the scraper worker should run a full pass, in hours.
SCRAPER_INTERVAL_HOURS=6

# -----------------------------------------------------------------------------
# Observability (Sentry)
# -----------------------------------------------------------------------------

# Sentry DSN. Leave empty to disable Sentry. Optional.
SENTRY_DSN=

# Environment tag reported to Sentry (usually mirrors ENVIRONMENT).
SENTRY_ENVIRONMENT=development

# Fraction of transactions sent to Sentry for performance monitoring (0.0 - 1.0).
SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# CI/CD secrets (DO NOT set these in local .env files)
# -----------------------------------------------------------------------------

# Fly.io API token used by GitHub Actions to deploy. CI/CD only.
FLY_API_TOKEN=

# GitHub Container Registry token used to push/pull images. CI/CD only.
GHCR_TOKEN=

# -----------------------------------------------------------------------------
# Postgres credentials (used by docker-compose for the local `postgres` service)
# Keep these in sync with DATABASE_URL above.
# -----------------------------------------------------------------------------

POSTGRES_USER=koko
POSTGRES_PASSWORD=koko_dev
POSTGRES_DB=koko_mls

# -----------------------------------------------------------------------------
# Backups (consumed by infra/backup.sh)
# -----------------------------------------------------------------------------

# Target S3 bucket where pg_dump archives are uploaded.
BACKUP_S3_BUCKET=

# AWS credentials with write access to BACKUP_S3_BUCKET.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Internal service auth
# -----------------------------------------------------------------------------

# Shared secret used by the cron worker (and other internal callers)
# to authenticate against the API.
INTERNAL_API_KEY=
